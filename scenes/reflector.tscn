[gd_scene format=3]

[ext_resource type="Texture2D" path="res://assets/Misc/floodlight.png" id="1_tex"]

[sub_resource type="Shader" id="Shader_cone"]
code = "shader_type canvas_item;
varying float v_y;
varying float v_x;
void vertex() {
	v_y = VERTEX.y;
	v_x = VERTEX.x;
}
void fragment() {
	float tip = 400.0;
	float t = clamp(v_y / tip, 0.0, 1.0);
	// half-width of cone at this depth (expands 0->260 then contracts 260->400)
	float hw = t < 0.65 ? mix(6.0, 80.0, t / 0.65) : mix(80.0, 0.0, (t - 0.65) / 0.35);
	// how close to the lateral edge (0 = center, 1 = edge)
	float edge_t = hw > 0.0 ? clamp(abs(v_x) / hw, 0.0, 1.0) : 1.0;
	float edge_soft = 1.0 - smoothstep(0.6, 1.0, edge_t);
	float length_fade = pow(1.0 - t, 1.1);
	COLOR.a *= length_fade * edge_soft;
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_cone"]
shader = SubResource("Shader_cone")

[node name="Reflector" type="Node2D"]

